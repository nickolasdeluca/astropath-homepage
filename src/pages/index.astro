---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Astropath — Nickolas de Luca Alberton">

  <!-- ═══ Navigation ═══ -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="#hero" class="nav-logo">✦ Astropath ✦</a>
      <ul class="nav-links">
        <li><a href="#dossier">Dossier</a></li>
        <li><a href="#arsenal">Arsenal</a></li>
        <li><a href="#forge-works">Forge Works</a></li>
        <li><a href="#vox-channel">Vox-Channel</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Toggle navigation menu" aria-expanded="false">☰</button>
    </div>
  </nav>

  <!-- ═══ Hero ═══ -->
  <section id="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-ornament" aria-hidden="true">⚙</div>
    <div class="container hero-content">
      <p class="hero-badge">Inquisitorial Data-Slate · Ref: NDL-10-07 · Clearance: Vermilion</p>
      <div class="hero-divider" aria-hidden="true">✦</div>
      <h1 class="hero-name">Nickolas<br />de Luca Alberton</h1>
      <div class="hero-divider" aria-hidden="true">✦</div>
      <p class="hero-title">Magos Digitalis &middot; Forge-Adept of the Omnissiah</p>
      <p class="hero-bio">
        Bridging the void between concept and code —<br />
        one sacred iteration at a time.
      </p>
      <div class="hero-actions">
        <a href="#forge-works" class="btn btn-primary">View Forge Works</a>
        <a href="#vox-channel" class="btn btn-secondary">Establish Contact</a>
      </div>
    </div>
  </section>

  <!-- ═══ Dossier ═══ -->
  <section id="dossier" class="section">
    <div class="container">
      <p class="section-label">✦ Inquisitorial Record ✦</p>
      <h2 class="section-heading">Dossier</h2>
      <div class="dossier-grid">
        <div class="dossier-text">
          <p class="dossier-classification">
            File Ref: ADPT-NDL-7041 &nbsp;·&nbsp; Status: Active Service &nbsp;·&nbsp; Clearance: Standard
          </p>
          <p>
            Blessed by the Omnissiah with over a decade of service in the cogitation-arts,
            <strong>Adept Nickolas de Luca Alberton</strong> began his crusade on the front lines
            of Technical Support — mastering the sacred art of interfacing with un-augmented
            mortals before ascending through the orders of the Machine Cult.
          </p>
          <p>
            Guided by the Binary Cant and the Rites of Debugging, he progressed through the
            esoteric disciplines of Quality Assurance and Test Automation, ultimately achieving
            the rank of <strong>Forge-Adept</strong>. Where lesser servants fulfill a single
            function, this Adept performs three with equal mastery: he <em>crafts</em>,
            he <em>tests</em>, he <em>qualifies</em>.
          </p>
          <p>
            His current campaign is the mobile frontier, where he wields <strong>Flutter</strong>
            as both blade and shield — fighting the eternal crusade against defect, latency, and
            technical debt in the name of the Omnissiah.
          </p>
        </div>
        <div class="dossier-stats">
          <div class="stat-card">
            <span class="stat-number">10+</span>
            <span class="stat-label">Years of Service</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">20+</span>
            <span class="stat-label">Forge Constructs</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">3-in-1</span>
            <span class="stat-label">Dev · QA · Automator</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">∞</span>
            <span class="stat-label">Caffeine Units</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Arsenal ═══ -->
  <section id="arsenal" class="section">
    <div class="container">
      <p class="section-label">✦ Litanies of the Omnissiah ✦</p>
      <h2 class="section-heading">Arsenal</h2>
      <p class="section-desc">
        These are the sacred rites spoken in service to the Machine God. Each has been mastered
        through countless cycles of iteration, tested against the entropy of legacy systems
        and living codebases.
      </p>
      <div class="arsenal-grid">
        <div class="arsenal-col">
          <h3 class="arsenal-cat">⚙ Binary Cant</h3>
          <p class="arsenal-sub">Programming Languages</p>
          <div class="skill-tags">
            <span class="skill-tag featured">Dart</span>
            <span class="skill-tag featured">Delphi / Pascal</span>
            <span class="skill-tag">JavaScript</span>
            <span class="skill-tag">TypeScript</span>
            <span class="skill-tag">Python</span>
          </div>
        </div>
        <div class="arsenal-col">
          <h3 class="arsenal-cat">⚙ Battle Rites</h3>
          <p class="arsenal-sub">Frameworks &amp; Platforms</p>
          <div class="skill-tags">
            <span class="skill-tag featured">Flutter</span>
            <span class="skill-tag">Next.js</span>
            <span class="skill-tag">Node.js</span>
            <span class="skill-tag">React</span>
            <span class="skill-tag">Astro</span>
          </div>
        </div>
        <div class="arsenal-col">
          <h3 class="arsenal-cat">⚙ Sacred Instruments</h3>
          <p class="arsenal-sub">Tools &amp; Environments</p>
          <div class="skill-tags">
            <span class="skill-tag featured">VS Code</span>
            <span class="skill-tag">RAD Studio</span>
            <span class="skill-tag">Android Studio</span>
            <span class="skill-tag">Git</span>
            <span class="skill-tag">Docker</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Forge Works ═══ -->
  <section id="forge-works" class="section">
    <div class="container">
      <p class="section-label">✦ Constructs of the Digital Forge ✦</p>
      <h2 class="section-heading">Forge Works</h2>
      <p class="section-desc">
        These constructs have been forged in the sacred workshops of the Omnissiah and offered
        freely to the binary commons — for the glory of open-source and the benefit of future Adepts.
      </p>
      <div class="projects-grid">
        <a
          href="https://github.com/nickolasdeluca/flutter_modal_dialog"
          target="_blank"
          rel="noopener noreferrer"
          class="project-card"
        >
          <span class="project-lang dart">Dart</span>
          <h3 class="project-name">flutter_modal_dialog</h3>
          <p class="project-desc">
            A servo-construct providing simple modal dialogs for common user interactions
            within Flutter battle-forms. Lightweight and battle-tested.
          </p>
          <div class="project-footer">
            <span>⭐ 1 commendation</span>
            <span class="project-arrow">View Construct →</span>
          </div>
        </a>

        <a
          href="https://github.com/nickolasdeluca/UrlParser"
          target="_blank"
          rel="noopener noreferrer"
          class="project-card"
        >
          <span class="project-lang pascal">Pascal</span>
          <h3 class="project-name">UrlParser</h3>
          <p class="project-desc">
            A Node.js-like URL constructor implemented in the ancient rites of Delphi and Pascal.
            Bridges the old ways with modern incantations.
          </p>
          <div class="project-footer">
            <span>⭐ 14 commendations</span>
            <span class="project-arrow">View Construct →</span>
          </div>
        </a>

        <a
          href="https://github.com/nickolasdeluca/ssw-tracker"
          target="_blank"
          rel="noopener noreferrer"
          class="project-card"
        >
          <span class="project-lang js">JavaScript</span>
          <h3 class="project-name">ssw-tracker</h3>
          <p class="project-desc">
            A tracking servo-automaton for monitoring cargo packages through specific
            logistical channels. Swift and reliable reconnaissance tool.
          </p>
          <div class="project-footer">
            <span>⬦ Public Construct</span>
            <span class="project-arrow">View Construct →</span>
          </div>
        </a>

        <a
          href="https://github.com/nickolasdeluca/pino-discord-transport"
          target="_blank"
          rel="noopener noreferrer"
          class="project-card"
        >
          <span class="project-lang js">JavaScript</span>
          <h3 class="project-name">pino-discord-transport</h3>
          <p class="project-desc">
            A vox-relay construct that transmits Pino log-data to Discord astropathic
            channels. Because even the Machine God needs its logs monitored.
          </p>
          <div class="project-footer">
            <span>⭐ 2 commendations</span>
            <span class="project-arrow">View Construct →</span>
          </div>
        </a>
      </div>
      <div class="projects-cta">
        <a
          href="https://github.com/nickolasdeluca?tab=repositories"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-secondary"
        >
          View All Constructs on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ Vox-Channel ═══ -->
  <section id="vox-channel" class="section">
    <div class="container">
      <p class="section-label">✦ Astropathic Relay ✦</p>
      <h2 class="section-heading">Vox-Channel</h2>
      <p class="section-desc">
        Transmit your signal through any of the relay-channels below.
        The Adept shall respond with haste — the Omnissiah willing.
      </p>
      <div class="contact-grid">
        <a
          href="https://github.com/nickolasdeluca"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <div class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="34" height="34" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <h3 class="contact-name">GitHub</h3>
          <p class="contact-handle">@nickolasdeluca</p>
          <p class="contact-desc">Primary repository and construct archive of the Forge.</p>
        </a>

        <a
          href="https://www.linkedin.com/in/nickolasdeluca"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <div class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="34" height="34" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <h3 class="contact-name">LinkedIn</h3>
          <p class="contact-handle">Nickolas de Luca Alberton</p>
          <p class="contact-desc">Professional dossier and official service record.</p>
        </a>

        <a
          href="https://twitter.com/nickolasdelucaa"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
        >
          <div class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="34" height="34" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </div>
          <h3 class="contact-name">X / Twitter</h3>
          <p class="contact-handle">@nickolasdelucaa</p>
          <p class="contact-desc">Short-range vox broadcasts from across the void.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ Footer ═══ -->
  <footer>
    <div class="container">
      <p class="footer-logo">✦ Astropath ✦</p>
      <p class="footer-quote">
        "In the grim darkness of the digital frontier, there is only code."
      </p>
      <p class="footer-copy">
        &copy; 2026 Nickolas de Luca Alberton &nbsp;·&nbsp; Omnissiah Vult &nbsp;·&nbsp;
        <a href="https://github.com/nickolasdeluca/astropath-homepage" target="_blank" rel="noopener noreferrer">Source</a>
      </p>
    </div>
  </footer>

</Layout>

<script>
  // ── Nav scroll state ──
  const nav = document.getElementById('nav')!;
  const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 60);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // ── Mobile nav toggle ──
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle')!;
  const links  = document.querySelector<HTMLElement>('.nav-links')!;
  toggle.addEventListener('click', () => {
    const isOpen = links.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.textContent = isOpen ? '✕' : '☰';
  });

  // Close mobile nav on link click
  links.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.textContent = '☰';
    })
  );

  // ── Section reveal on scroll ──
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.07 }
  );
  document.querySelectorAll('.section').forEach(s => observer.observe(s));
</script>
